# Document OCR benchmark / service configuration.
# Copy to .env and adjust. Names match the service spec's Configuration section.

# --- General ---------------------------------------------------------------
OCR_DEFAULT_PROVIDER=tesseract
# Comma-separated. JSON list also accepted by pydantic-settings.
OCR_ALLOWED_PROVIDERS=["qwen-vl","glm-ocr","paddleocr-vl","tesseract"]
OCR_LOCAL_ONLY_MODE=false
OCR_MAX_IMAGE_BYTES=15728640
# CPU inference is slower; 120000 ms is a safer default for compose runs.
OCR_SYNC_TIMEOUT_MS=120000
OCR_DEBUG_OUTPUT_ENABLED=false
# Set false when no NVIDIA GPU is present (harness still runs; report GPU column is —).
OCR_GPU_QUERY_ENABLED=true

# --- Qwen-VL (OpenAI-compatible, served via vLLM) --------------------------
OCR_PROVIDER_QWEN_VL_ENDPOINT=http://qwen-vllm:8000/v1
OCR_PROVIDER_QWEN_VL_API_KEY=
OCR_PROVIDER_QWEN_VL_MODEL=Qwen/Qwen3-VL-8B-Instruct

# --- GLM-OCR ---------------------------------------------------------------
OCR_PROVIDER_GLM_OCR_ENDPOINT=http://glm-vllm:8000/v1
OCR_PROVIDER_GLM_OCR_API_KEY=
OCR_PROVIDER_GLM_OCR_MODEL=zai-org/GLM-OCR

# --- PaddleOCR-VL ----------------------------------------------------------
OCR_PROVIDER_PADDLEOCR_VL_ENDPOINT=http://paddle-vllm:8000/v1
OCR_PROVIDER_PADDLEOCR_VL_API_KEY=
OCR_PROVIDER_PADDLEOCR_VL_MODEL=PaddlePaddle/PaddleOCR-VL

# --- olmOCR ----------------------------------------------------------------
OCR_PROVIDER_OLMOCR_ENDPOINT=http://olmocr-vllm:8000/v1
OCR_PROVIDER_OLMOCR_API_KEY=
OCR_PROVIDER_OLMOCR_MODEL=allenai/olmOCR-2-7B-1025

# --- Classical fallback ----------------------------------------------------
OCR_PROVIDER_TESSERACT_ENABLED=true
OCR_TESSERACT_LANG=eng

# --- Model server (vLLM via docker-compose) --------------------------------
# Hugging Face token for downloading weights (Settings → Access Tokens).
HUGGING_FACE_HUB_TOKEN=

# CPU serving (default in docker-compose.yml). Pick the tag for your platform:
#   Linux x86_64: vllm/vllm-openai-cpu:latest-x86_64
#   Linux arm64 / Apple Silicon: vllm/vllm-openai-cpu:latest-arm64
VLLM_IMAGE=vllm/vllm-openai-cpu:latest-x86_64
# KV cache budget in GiB per vLLM process (raise if you have RAM and want concurrency).
VLLM_CPU_KVCACHE_SPACE=4
# auto | nobind | 0-31 (see vLLM CPU docs)
VLLM_CPU_OMP_THREADS_BIND=auto

# GPU serving (optional): use docker-compose.gpu.yml and set:
# VLLM_GPU_IMAGE=vllm/vllm-openai:latest
